{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git add:*)",
      "Bash(git rev-list:*)",
      "Bash(git status:*)",
      "mcp__*atlassianUserInfo",
      "mcp__*getAccessibleAtlassianResources",
      "mcp__*getVisibleJiraProjects",
      "mcp__*pull_request_read",
      "mcp__*searchJiraIssuesUsingJql"
    ],
    "deny": ["Bash(rm:*)", "Read(*.env)"],
    "ask": [
      "Bash(curl:*)",
      "Bash(gh pr create:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/Users/brendon/.dotfiles",
      "/Users/brendon/code",
      "/Users/brendon/dev",
      "/Users/bsmith/.dotfiles",
      "/Users/bsmith/code",
      "/Users/bsmith/dev"
    ]
  }
}
