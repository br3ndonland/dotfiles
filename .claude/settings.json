{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "mcp__*atlassianUserInfo",
      "mcp__*getAccessibleAtlassianResources",
      "mcp__*getVisibleJiraProjects",
      "mcp__*pull_request_read",
      "mcp__*searchJiraIssuesUsingJql",
      "Read"
    ],
    "deny": [],
    "ask": [
      "Bash(curl*)",
      "Bash(gh * delete *)",
      "Bash(gh pr close *)",
      "Bash(gh pr create *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git tag *)",
      "Bash(rm*)",
      "Bash(vercel * delete *)",
      "Bash(vercel remove *)",
      "Bash(vercel rm *)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/Users/brendon/code",
      "/Users/bsmith/code"
    ]
  },
  "model": "opus[1m]",
  "worktree": {
    "symlinkDirectories": [
      ".cache",
      ".venv",
      "node_modules"
    ]
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {},
  "effortLevel": "high"
}
