# Codex default rules
#
# https://developers.openai.com/codex/rules
# https://developers.openai.com/codex/agent-approvals-security
# https://github.com/bazelbuild/starlark/blob/master/spec.md

# Without the following rule, Codex will prompt before creating new branches.
# This is because `.git` is a protected path in writable roots.
# This rule allows Codex to create branches while still maintaining a secure sandbox.
prefix_rule(
  pattern=[
    "git",
    [
      "add",
      "branch",
      "checkout",
      "cherry-pick",
      "commit",
      "fetch",
      "merge",
      "pull",
      "rebase",
      "stash",
      "switch",
      "worktree",
    ]
  ],
  decision="allow",
  justification="Allow agents to create and checkout branches and worktrees",
  match=[
      "git checkout -b codex/new-feature",
      "git switch -c codex/new-feature",
  ],
)

prefix_rule(
  pattern=[
    "git",
    "branch",
    [
      "--delete",
      "-d",
    ],
    "main",
  ],
  decision="forbidden",
  justification="Forbid agents from deleting the default branch",
  match=[
      "git branch --delete main",
      "git branch -d main",
  ],
)

prefix_rule(
  pattern=[
    "git",
    "push",
    [
      "--delete",
      "-d",
    ],
  ],
  decision="forbidden",
  justification="Forbid agents from deleting remote tracking branches",
  match=[
      "git push --delete upstream feature",
      "git push -d origin main",
  ],
)

# This rule complements the suggestion in `AGENTS.md` of preferring `trash` over `rm`.
prefix_rule(
  pattern=[
    "trash",
  ],
  decision="allow",
  justification="Allow agents to move files to the trash as a safer alternative to rm",
  match=[
    "trash /tmp/dir",
    "trash ~/code/file.txt",
  ],
)
