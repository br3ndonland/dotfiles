# https://spec.editorconfig.org/
root = true

[*]
# general options
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
# shfmt options - https://github.com/mvdan/sh/blob/HEAD/cmd/shfmt/shfmt.1.scd
apply_ignore = true

[*.py]
indent_size = 4

[*{zprofile,zsh}*]
# shfmt now supports zsh
# https://github.com/mvdan/sh/issues/120
# https://github.com/mvdan/sh/releases/tag/v3.13.0
ignore = false
