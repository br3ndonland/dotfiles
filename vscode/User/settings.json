{
  // General settings
  "breadcrumbs.enabled": true,
  "debug.toolBarLocation": "docked",
  "editor.autoClosingQuotes": "beforeWhitespace",
  "editor.autoIndent": "advanced",
  "editor.bracketPairColorization.enabled": false,
  "editor.cursorBlinking": "phase",
  "editor.detectIndentation": false,
  "editor.inlineSuggest.enabled": true,
  "editor.insertSpaces": true,
  "editor.fontFamily": "'Rec Mono Duotone', 'Dank Mono', 'Fira Code', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.minimap.enabled": false,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false,
  },
  "editor.renderWhitespace": "none",
  "editor.suggest.preview": true,
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.unicodeHighlight.nonBasicASCII": true,
  "editor.wordWrap": "off",
  "emmet.triggerExpansionOnTab": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.decorations.badges": false,
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  "extensions.ignoreRecommendations": true,
  "extensions.supportUntrustedWorkspaces": {
    "streetsidesoftware.code-spell-checker": {
      "supported": "limited",
    },
    "yzhang.markdown-all-in-one": {
      "supported": "limited",
    },
  },
  "files.associations": {
    "{**/*.env,**/env}": "dotenv",
    "**/.zfunc/*": "shellscript",
    "**/*.hujson": "jsonc",
    "**/*.rego*": "rego",
  },
  "files.autoSave": "onWindowChange",
  "files.exclude": {
    "**/._*": true,
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.venv/**": true,
  },
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left",
  },
  "task.allowAutomaticTasks": "off",
  "telemetry.telemetryLevel": "off",
  "terminal.external.osxExec": "Terminal.app",
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal",
  ],
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.minimumContrastRatio": 1,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.tabs.enabled": false,
  "update.mode": "manual",
  "update.showReleaseNotes": false,
  "window.commandCenter": true,
  "window.confirmSaveUntitledWorkspace": false,
  "window.newWindowDimensions": "maximized",
  "window.restoreWindows": "all",
  "window.zoomLevel": 1,
  "workbench.colorTheme": "Dracula Pro",
  "workbench.editor.historyBasedLanguageDetection": false,
  "workbench.editor.languageDetection": false,
  "workbench.editor.pinnedTabSizing": "compact",
  "workbench.editorAssociations": {
    "git-rebase-todo": "default",
    "*.ipynb": "jupyter-notebook",
  },
  "workbench.enableExperiments": false,
  "workbench.fontAliasing": "auto",
  "workbench.settings.editor": "json",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.startupEditor": "none",
  // Git
  "[git-commit][git-rebase]": {
    "editor.quickSuggestions": {
      "comments": "off",
      "other": "off",
      "strings": "off",
    },
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,
  "diffEditor.renderSideBySideInlineBreakpoint": 0,
  "git.autofetch": false,
  "git.autoRepositoryDetection": "subFolders",
  "git.confirmSync": true,
  "git.enableCommitSigning": true,
  "git.enableSmartCommit": true,
  "git.inputValidation": true,
  "git.mergeEditor": false,
  "git.repositoryScanMaxDepth": 5,
  "github.gitProtocol": "ssh",
  "gitless.defaultDateFormat": "YYYY-MM-DD HH:mm",
  "gitless.defaultDateStyle": "absolute",
  "gitless.repositoryScanMaxDepth": 5,
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  // AI
  "chat.commandCenter.enabled": false,
  "chatgpt.followUpQueueMode": "steer",
  "claudeCode.disableLoginPrompt": true,
  "kilo-code.new.autocomplete.enableAutoTrigger": false,
  "kilo-code.new.autocomplete.enableSmartInlineTaskKeybinding": true,
  "kilo-code.new.autocomplete.enableChatAutocomplete": false,
  "kilo-code.new.showTaskTimeline": false,
  // Language-specific settings
  "aws.onDefaultRegionMissing": "add",
  "aws.profile": "profile:default",
  "aws.telemetry": false,
  "cSpell.autoFormatConfigFile": false,
  "cSpell.diagnosticLevel": "Information",
  "cSpell.import": ["~/.dotfiles/vscode/User/cspell.json"],
  "cSpell.spellCheckDelayMs": 5000,
  "deno.unstable": false,
  "[dockerfile]": {
    "editor.formatOnSave": false,
  },
  "eslint.enable": false,
  "go.survey.prompt": false,
  "go.toolsManagement.autoUpdate": false,
  "go.toolsManagement.checkForUpdates": "local",
  "gopls": { "ui.semanticTokens": true },
  "grunt.autoDetect": "off",
  "gulp.autoDetect": "off",
  "json.schemaDownload.trustedDomains": {
    "https://app.kilo.ai/config.json": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://docs.renovatebot.com/renovate-schema.json": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://models.dev/model-schema.json": true,
    "https://opencode.ai/config.json": true,
    "https://opencode.ai/tui.json": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://www.schemastore.org/": true,
  },
  "json.schemas": [
    {
      "fileMatch": ["*.hujson"],
      "schema": {
        "allowTrailingCommas": true,
      },
    },
  ],
  "[astro][css][dockercompose][github-actions-workflow][html][javascript][javascriptreact][json][jsonc][markdown][mdx][snippets][typescript][typescriptreact][vue][yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "markdown.extension.italic.indicator": "_",
  "markdown.extension.list.indentationSize": "inherit",
  "markdown.extension.print.absoluteImgPath": false,
  "markdown.extension.toc.slugifyMode": "github",
  "markdown.extension.toc.levels": "2..3",
  "markdown.extension.toc.updateOnSave": true,
  "opa.dependency_paths.regal": "regal",
  "opa.languageServers": ["regal"],
  "opentofu.experimentalFeatures.prefillRequiredFields": true,
  "opentofu.experimentalFeatures.validateOnSave": true,
  "[opentofu][opentofu-vars]": {
    "editor.defaultFormatter": "opentofu.vscode-opentofu",
  },
  "[rego]": {
    "editor.codeLens": false,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.insertSpaces": false,
  },
  "[plaintext]": {
    "editor.quickSuggestions": {
      "comments": "off",
      "other": "off",
      "strings": "off",
    },
  },
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.organizeImports": "always",
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.rulers": [],
    "editor.tabSize": 4,
  },
  "python.experiments.enabled": false,
  "python.experiments.optOutFrom": ["All"],
  "python.languageServer": "None", // set to "None" for BasedPyright
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "python.testing.promptToConfigure": false,
  "ruff.lint.extendSelect": ["I", "UP"],
  "redhat.telemetry.enabled": false,
  "shellcheck.enable": true,
  "shellcheck.run": "onSave",
  "shellcheck.exclude": [
    "SC1071", // only supports sh/bash/dash/ksh
    "SC1090", // can't follow non-constant source
    "SC1091", // not following source
  ],
  "shellcheck.ignoreFileSchemes": ["git", "gitfs"],
  "shellcheck.ignorePatterns": {
    "**/*.zsh": false,
    "**/*.zshrc": false,
    "**/zshrc": false,
  },
  "shfmt.formatIgnored": false,
  "[shellscript]": {
    "editor.rulers": [],
    "files.eol": "\n",
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode",
  },
  "svelte.enable-ts-plugin": true,
  "[toml]": {
    "editor.defaultFormatter": "tombi-toml.tombi",
  },
  "js/ts.implementationsCodeLens.enabled": true,
  "js/ts.implementationsCodeLens.showOnInterfaceMethods": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.referencesCodeLens.enabled": true,
  "vetur.experimental.templateInterpolationService": true,
  "vetur.format.defaultFormatter.css": "prettier",
  "vetur.format.defaultFormatter.html": "prettier",
  "vetur.format.defaultFormatter.js": "prettier",
  "vetur.format.defaultFormatter.ts": "prettier",
  "vetur.format.options.tabSize": 2,
  "vetur.format.options.useTabs": false,
  "vetur.ignoreProjectWarning": true,
  "yaml.format.enable": false,
}
